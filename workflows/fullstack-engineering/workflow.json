{
  "name": "fullstack-engineering",
  "version": "0.1.8",
  "description": "Full-stack engineering workflow scaffold for iterating across codebase understanding, implementation, validation, and delivery",
  "marketplaceDescription": "Iterate on full-stack engineering tasks across codebase understanding, implementation, validation, and delivery",
  "promptTemplate": "{input}",
  "workflowFile": "workflow.md",
  "loop": {
    "enabled": true,
    "maxIterations": 100
  },
  "examplePrompts": [
    "Implement a new settings page and backend endpoint",
    "Fix a production bug across the API and UI",
    "Add a full-stack feature with tests and delivery notes"
  ],
  "plugins": [
    {
      "ref": "agent-web-interface@lespaceman/athena-workflow-marketplace",
      "version": "1.0.12"
    },
    {
      "ref": "app-exploration@lespaceman/athena-workflow-marketplace",
      "version": "0.1.8"
    },
    {
      "ref": "frontend-design@lespaceman/athena-workflow-marketplace",
      "version": "0.1.2"
    },
    {
      "ref": "shadcn@lespaceman/athena-workflow-marketplace",
      "version": "0.1.1"
    },
    {
      "ref": "linear@lespaceman/athena-workflow-marketplace",
      "version": "0.1.2"
    },
    {
      "ref": "matt-pocock-skills@lespaceman/athena-workflow-marketplace",
      "version": "0.1.4"
    },
    {
      "ref": "exploratory-testing@lespaceman/athena-workflow-marketplace",
      "version": "0.2.6"
    },
    {
      "ref": "test-analysis@lespaceman/athena-workflow-marketplace",
      "version": "0.2.9"
    },
    {
      "ref": "playwright-automation@lespaceman/athena-workflow-marketplace",
      "version": "0.1.7"
    },
    {
      "ref": "smoke-testing@lespaceman/athena-workflow-marketplace",
      "version": "0.1.3"
    },
    {
      "ref": "regression-testing@lespaceman/athena-workflow-marketplace",
      "version": "0.1.4"
    }
  ]
}
